# Postgres connection used by Prisma
DATABASE_URL="postgresql://user:password@localhost:5432/sub_tracker?schema=public"

# AES-256-GCM key used to encrypt Plaid access tokens at rest.
# Must be exactly 32 bytes, base64-encoded.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=""
TOKEN_ENCRYPTION_KEY_VERSION=1

# Auth.js / Google OAuth
# Generate with: npx auth secret
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_URL="http://localhost:3000"

# Plaid Sandbox
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV=sandbox
# PLAID_REDIRECT_URI=

# Merchant cancellation-link search
SERPER_API_KEY=""

# ---------- Invite emails (Gmail SMTP) ----------
# The sending Gmail account must have 2FA enabled and an App Password
# generated at https://myaccount.google.com/apppasswords
# (Account > Security > 2-Step Verification > App passwords).
# The app password is 16 letters (no spaces) or 4 groups of 4 separated
# by spaces; either form works with Nodemailer.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
GMAIL_FROM_NAME="Sub-Tracker"
